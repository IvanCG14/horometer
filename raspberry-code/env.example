# Smart Hour Meter v3 - Environment Configuration
# Archivo .env para desarrollo en Windows
# Copiar a .env y completar con tus valores reales

# ============================================================================
# SQL SERVER CONFIGURATION
# ============================================================================

# Servidor SQL Server
DB_SERVER=192.168.1.50\SQLEXPRESS
# Alternativa: DB_SERVER=localhost\SQLEXPRESS (si está en local)

# Nombre de la base de datos
DB_NAME=ERP_Production

# Usuario SQL Server
DB_USER=sa

# Contraseña SQL Server
DB_PASSWORD=tu_contraseña_aqui

# Puerto SQL Server (típicamente 1433)
DB_PORT=1433

# Configuración ODBC
# Dejar vacío para usar Driver 17 por defecto
ODBC_DRIVER=ODBC Driver 17 for SQL Server

# ============================================================================
# CONFIGURACIÓN DEL CENTRO DE TRABAJO
# ============================================================================

# Centro de trabajo (TORNO 17, TORNO 18, etc)
WORK_CENTER=TORNO 17

# ============================================================================
# CONFIGURACIÓN DE GPIO (Solo Raspberry Pi, ignorar en Windows)
# ============================================================================

# Pines GPIO
GPIO_VFD_SIGNAL=17
GPIO_BTN_UP=27
GPIO_BTN_DOWN=22
GPIO_BTN_CONFIRM=23

# ============================================================================
# CONFIGURACIÓN DE LCD I2C (Solo Raspberry Pi, ignorar en Windows)
# ============================================================================

# Dirección I2C del LCD
LCD_ADDRESS=0x27

# Puerto I2C (típicamente 1 para Raspberry Pi)
LCD_PORT=1

# ============================================================================
# CONFIGURACIÓN DE TIMING
# ============================================================================

# Debounce de botones en milisegundos
BUTTON_DEBOUNCE_MS=50

# Debounce de VFD en milisegundos
VFD_DEBOUNCE_MS=150

# Intervalo de actualización de pantalla en milisegundos
UPDATE_INTERVAL_MS=100

# Loop delay en segundos
LOOP_DELAY_SEC=0.1

# ============================================================================
# TIMEOUT DE SESIÓN
# ============================================================================

# Timeout máximo de sesión en segundos (5 horas = 18000)
SESSION_TIMEOUT_SEC=18000

# ============================================================================
# LOGGING
# ============================================================================

# Nivel de logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Archivo de log (vacío = solo consola)
LOG_FILE=smart_hour_meter.log

# ============================================================================
# DESARROLLO (Windows)
# ============================================================================

# Modo desarrollo (True/False)
DEV_MODE=True

# Usar mocks de GPIO y LCD en desarrollo
USE_MOCKS=True

# ============================================================================
# NOTAS PARA USUARIOS
# ============================================================================

# WINDOWS:
# 1. Copiar este archivo a .env (en la carpeta del proyecto)
# 2. Llenar los valores según tu configuración
# 3. Instalar ODBC Driver 17: https://www.microsoft.com/en-us/download/details.aspx?id=56567
# 4. Ejecutar: python smart_hour_meter_v3_windows_dev.py
#
# RASPBERRY PI:
# 1. Copiar este archivo a /opt/smart_hour_meter/.env
# 2. Ajustar valores de GPIO y LCD según tu hardware
# 3. install_v3_rpi.sh se encargará del resto
# 4. Ejecutar: systemctl start smart-hour-meter

# ============================================================================
# EJEMPLO DE CADENA DE CONEXIÓN GENERADA
# ============================================================================

# Con los valores arriba, la cadena ODBC sería:
# Driver={ODBC Driver 17 for SQL Server};
# Server=192.168.1.50\SQLEXPRESS;
# Database=ERP_Production;
# UID=sa;
# PWD=tu_contraseña_aqui;
# Port=1433;
# TrustServerCertificate=yes
